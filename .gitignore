# ⚠️ RENOMME CE FICHIER EN ".gitignore" (avec le point) APRÈS TÉLÉCHARGEMENT

# Flutter/Dart
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
*.dart.js
*.info.json
*.js
*.js.deps
*.js.map

# Android
android/.gradle/
android/app/debug
android/app/profile
android/app/release
android/local.properties
*.apk
*.aab

# iOS
ios/.symlinks/
ios/Pods/
ios/Podfile.lock
ios/.generated/
ios/Flutter/App.framework
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
ios/Flutter/ephemeral/
ios/ServiceDefinitions.json
ios/Runner/GeneratedPluginRegistrant.*

# Xcode
**/xcuserdata/
*.xcworkspace
!Runner.xcworkspace
*.xcuserstate
*.moved-aside
*.pbxuser
DerivedData/
.swiftpm/

# IDE
.idea/
*.iml
.vscode/
*.suo
*.user
*.userosscache
*.sln.docstates

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
*.lnk

# Secrets & API Keys (IMPORTANT!)
.env
*.env
secrets.dart
api_keys.dart
**/secrets/
**/private/

# Logs
*.log
logs/

# Test
coverage/
.test_coverage.dart

# Build artifacts
*.ipa
*.app
*.dSYM.zip
*.dSYM
